# In Range — environment configuration
# Copy to `.env` and fill real values. Never commit `.env`.

# --- Supabase (required for cloud) ---
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLISHABLE-KEY
# SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-KEY

# BLE correlation secrets (same on every client for an environment)
# Generate: openssl rand -hex 32
INRANGE_USER_ID_SECRET=
INRANGE_HMAC_SECRET=

# Encounter reveal delay: production=4, dual-phone lab=0
ENCOUNTER_REVEAL_DELAY_HOURS=4

# Foreground service (2nd Flutter engine) — leave false on Galaxy S9 lab
INRANGE_ENABLE_FGS=false

# Prefer server feeds when cloud is live
INRANGE_PREFER_SERVER=true

# OAuth redirect (must match Android intent-filter)
AUTH_REDIRECT_URL=io.inrange.app://login-callback

# Optional Google Web client ID (native Google Sign-In later)
GOOGLE_WEB_CLIENT_ID=

# Optional mock FCM token for register_push_token without Firebase
FCM_MOCK_TOKEN=
